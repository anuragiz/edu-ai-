{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "number", "description": "Server timestamp" }
      },
      "required": ["name", "email", "createdAt"]
    },
    "Discussion": {
      "title": "Discussion",
      "description": "Community chat post",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "tags": { "type": "array" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "likes": { "type": "number" },
        "dislikes": { "type": "number" },
        "createdAt": { "type": "number", "description": "Server timestamp" },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "tags", "authorId", "authorName", "likes", "dislikes", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Comment on a discussion",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["text", "authorId", "authorName", "createdAt"]
    },
    "Book": {
      "title": "Book",
      "description": "A book explicitly added to the library.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "fileName": { "type": "string" },
        "fileSize": { "type": "number" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "number", "description": "Server timestamp" },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "description", "authorId", "authorName", "createdAt"]
    },
    "ChatRoom": {
      "title": "Chat Room",
      "description": "A private chat between two users",
      "type": "object",
      "properties": {
        "participants": { "type": "array" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "number" }
      },
      "required": ["participants", "updatedAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message within a chat room",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["text", "senderId", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile"
    },
    "discussions/{discussionId}": {
      "schema": { "$ref": "#/entities/Discussion" },
      "description": "Community discussions"
    },
    "discussions/{discussionId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Comments on a community discussion"
    },
    "books/{bookId}": {
      "schema": { "$ref": "#/entities/Book" },
      "description": "Library of public books"
    },
    "chats/{chatId}": {
      "schema": { "$ref": "#/entities/ChatRoom" },
      "description": "Private chat rooms"
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Chat messages inside a room"
    }
  }
}
